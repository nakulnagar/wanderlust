<% layout("/layouts/boilerplate") -%>

    

    <body>


      <div class="row mt-4">
        <div class="col-lg-10 mx-auto">

          <!-- Title -->
          <h2 class="fw-bold mb-2">
            <%= listing.title %>
          </h2>

          <!-- Location + Category -->
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="badge bg-light text-dark border">
              📍 <%= listing.location %>, <%= listing.country %>
            </span>

            <span class="badge bg-danger-subtle text-danger border">
              <%= listing.category %>
            </span>
          </div>

          <!-- Image -->
          <div class="card show-card listing-card mb-4">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
          </div>

          <!-- Info Grid -->
          <div class="row">

            <!-- Left: Description -->
            <div class="col-lg-8">

              <div class="mb-4">
                <h5 class="fw-semibold">Hosted by <%= listing.owner.username %>
                </h5>
                <p class="text-muted mb-2">
                  Premium verified host on Wanderlust
                </p>
              </div>

              <div class="mb-4">
                <h5 class="fw-semibold">About this place</h5>
                <p class="fs-6">
                  <%= listing.description %>
                </p>
              </div>

            </div>

            <!-- Right: Price Card -->
            <div class="col-lg-4">

              <div class="card p-3 shadow-sm price-card">
                <h4 class="fw-bold mb-3">
                  ₹ <%= listing.price.toLocaleString("en-IN") %>
                    <span class="fs-6 fw-normal text-muted">/ night</span>
                </h4>

                <button class="btn btn-danger w-100 mb-2">
                  Reserve
                </button>

                <p class="text-muted small text-center">
                  You won’t be charged yet
                </p>
              </div>

            </div>
          </div>

        </div>
      </div>


      <br />



    <br></br>
      <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="row mt-3">
          <div class="col-8 offset-3">
            <!-- <div class="d-flex gap-3 mb-4"> -->
              <div class="d-flex justify-content-end gap-4 mb-3">

              <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger edit-btn">
                <i class="fa-solid fa-pen"></i>
                Edit
              </a>

              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                <button type="submit" class="btn btn-outline-dark">
                  <i class="fa-solid fa-trash"></i>
                  Delete
                </button>
              </form>
            </div>
          </div>
        </div>

        <% } %>



